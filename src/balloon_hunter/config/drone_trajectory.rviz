Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Grid
      Enabled: true
      Value: true
      Cell Size: 5
      Line Style:
        Line Width: 0.03
        Value: Lines
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 20
      Reference Frame: <Fixed Frame>

    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true
      Value: true
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Scale: 1

    - Class: rviz_default_plugins/Marker
      Name: GT Trajectory (green)
      Enabled: true
      Value: true
      Topic:
        Value: /drone/gt_trajectory
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable

    - Class: rviz_default_plugins/Marker
      Name: PX4 Trajectory (yellow)
      Enabled: true
      Value: true
      Topic:
        Value: /drone/px4_trajectory
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable

    - Class: rviz_default_plugins/Marker
      Name: Balloon Marker
      Enabled: true
      Value: true
      Topic:
        Value: /balloon/marker
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable

    - Class: rviz_default_plugins/Marker
      Name: Mission State Text
      Enabled: true
      Value: true
      Topic:
        Value: /drone/state_text
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable

    - Class: rviz_default_plugins/Image
      Name: IBVS Debug Image
      Enabled: true
      Value: true
      Topic:
        Value: /ibvs/debug_image
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable
      Max Value: 1
      Median window: 5
      Min Value: 0
      Normalize Range: true

    - Class: rviz_default_plugins/Pose
      Name: Drone Pose
      Enabled: true
      Value: true
      Topic:
        Value: /drone/pose
        Depth: 5
        Durability Policy: Volatile
        Reliability Policy: Reliable
      Shape:
        Alpha: 1
        Axes Length: 1
        Axes Radius: 0.1
        Color: 0; 170; 255
        Head Length: 0.3
        Head Radius: 0.15
        Shaft Length: 0.5
        Shaft Radius: 0.05
        Value: Arrow

  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/FocusCamera
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 30
      Focal Point:
        X: 0
        Y: 5
        Z: 3
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.01
      Pitch: 0.5
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz)
      Yaw: 0.785
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Width: 1200
